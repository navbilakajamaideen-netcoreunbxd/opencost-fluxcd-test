 # clusters/minikube/capacitor/readonly-rbac.yaml
---
# ServiceAccount for Capacitor
apiVersion: v1
kind: ServiceAccount
metadata:
  name: capacitor-readonly
  namespace: capacitor-system
---
# ClusterRole with comprehensive read permissions
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: capacitor-readonly
rules:
# ===== FLUX SOURCE CRDs =====
- apiGroups: ["source.toolkit.fluxcd.io"]
  resources:
  - gitrepositories
  - helmrepositories
  - ocirepositories
  - buckets
  - helmcharts
  - artifacts
  verbs: ["get", "list", "watch"]

# ===== FLUX KUSTOMIZE CRDs =====
- apiGroups: ["kustomize.toolkit.fluxcd.io"]
  resources:
  - kustomizations
  verbs: ["get", "list", "watch"]

# ===== FLUX HELM CRDs =====
- apiGroups: ["helm.toolkit.fluxcd.io"]
  resources:
  - helmreleases
  - helmcharts
  verbs: ["get", "list", "watch"]

# ===== FLUX NOTIFICATION CRDs =====
- apiGroups: ["notification.toolkit.fluxcd.io"]
  resources:
  - providers
  - alerts
  - receivers
  verbs: ["get", "list", "watch"]

# ===== FLUX IMAGE CRDs =====
- apiGroups: ["image.toolkit.fluxcd.io"]
  resources:
  - imagepolicies
  - imagerepositories
  - imageupdateautomations
  verbs: ["get", "list", "watch"]

# ===== FLUX TERRAFORM CRDs =====
- apiGroups: ["infra.contrib.fluxcd.io"]
  resources:
  - terraforms
  verbs: ["get", "list", "watch"]

# ===== CORE KUBERNETES RESOURCES =====
- apiGroups: [""]
  resources:
  - configmaps
  - endpoints
  - persistentvolumeclaims
  - persistentvolumes
  - pods
  - pods/log
  - replicationcontrollers
  - serviceaccounts
  - services
  - nodes
  - events
  - limitranges
  - namespaces
  - resourcequotas
  - secrets
  verbs: ["get", "list", "watch"]

# ===== APPS RESOURCES =====
- apiGroups: ["apps"]
  resources:
  - controllerrevisions
  - daemonsets
  - deployments
  - replicasets
  - statefulsets
  verbs: ["get", "list", "watch"]

# ===== AUTOSCALING =====
- apiGroups: ["autoscaling"]
  resources:
  - horizontalpodautoscalers
  verbs: ["get", "list", "watch"]

# ===== BATCH =====
- apiGroups: ["batch"]
  resources:
  - cronjobs
  - jobs
  verbs: ["get", "list", "watch"]

# ===== NETWORKING =====
- apiGroups: ["networking.k8s.io"]
  resources:
  - ingresses
  - ingressclasses
  - networkpolicies
  verbs: ["get", "list", "watch"]

# ===== STORAGE =====
- apiGroups: ["storage.k8s.io"]
  resources:
  - storageclasses
  - volumeattachments
  - csidrivers
  - csinodes
  verbs: ["get", "list", "watch"]

# ===== RBAC =====
- apiGroups: ["rbac.authorization.k8s.io"]
  resources:
  - clusterrolebindings
  - clusterroles
  - rolebindings
  - roles
  verbs: ["get", "list", "watch"]

# ===== METRICS =====
- apiGroups: ["metrics.k8s.io"]
  resources:
  - nodes
  - pods
  verbs: ["get", "list", "watch"]

# ===== POLICY =====
- apiGroups: ["policy"]
  resources:
  - poddisruptionbudgets
  verbs: ["get", "list", "watch"]

# ===== API EXTENSIONS =====
- apiGroups: ["apiextensions.k8s.io"]
  resources:
  - customresourcedefinitions
  verbs: ["get", "list", "watch"]
---
# ClusterRoleBinding
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: capacitor-readonly
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: capacitor-readonly
subjects:
- kind: ServiceAccount
  name: capacitor-readonly
  namespace: capacitor-system

